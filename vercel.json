{
  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/article/:slug", "destination": "/api/og" },
    { "source": "/events/:slug", "destination": "/api/og" },
    { "source": "/events", "destination": "/api/og" },
    { "source": "/creator-voices/:slug", "destination": "/api/og" },
    { "source": "/creator-voices", "destination": "/api/og" },
    { "source": "/features/:slug", "destination": "/api/og" },
    { "source": "/features", "destination": "/api/og" },
    { "source": "/hub", "destination": "/api/og" },
    { "source": "/free-creators", "destination": "/api/og" },
    { "source": "/", "destination": "/api/og" },
    { "source": "/((?!api/)(?!assets/)(?!favicon/).*)", "destination": "/api/og" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
